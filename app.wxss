page {
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', 'Roboto', 'Helvetica Neue', Arial, sans-serif;
  background-color: #1a1a2e;
  color: #fff;
  font-size: 28rpx;
  line-height: 1.6;
}

.container {
  min-height: 100vh;
  padding: 30rpx;
  box-sizing: border-box;
}

.card {
  background: linear-gradient(135deg, #2a2a4a 0%, #1a1a2e 100%);
  border-radius: 24rpx;
  padding: 40rpx;
  margin-bottom: 30rpx;
  box-shadow: 0 10rpx 40rpx rgba(0, 0, 0, 0.3);
}

.title {
  font-size: 36rpx;
  font-weight: bold;
  color: #fff;
  margin-bottom: 30rpx;
}

.subtitle {
  font-size: 26rpx;
  color: #999;
  margin-bottom: 20rpx;
}

.btn-primary {
  background: linear-gradient(135deg, #ff6b9d 0%, #c44569 100%);
  color: #fff;
  border: none;
  border-radius: 50rpx;
  padding: 24rpx 60rpx;
  font-size: 32rpx;
  font-weight: bold;
  box-shadow: 0 10rpx 30rpx rgba(255, 107, 157, 0.4);
}

.btn-primary:active {
  opacity: 0.8;
  transform: scale(0.98);
}

.btn-secondary {
  background: rgba(255, 255, 255, 0.1);
  color: #fff;
  border: 2rpx solid rgba(255, 255, 255, 0.2);
  border-radius: 50rpx;
  padding: 24rpx 60rpx;
  font-size: 32rpx;
}

.btn-disabled {
  background: rgba(255, 255, 255, 0.1);
  color: #666;
  border: none;
  border-radius: 50rpx;
  padding: 24rpx 60rpx;
  font-size: 32rpx;
}

.btn-block {
  width: 100%;
  text-align: center;
  margin-top: 20rpx;
}

.btn-small {
  padding: 16rpx 40rpx;
  font-size: 28rpx;
}

.input-field {
  background: rgba(255, 255, 255, 0.08);
  border: 2rpx solid rgba(255, 255, 255, 0.1);
  border-radius: 16rpx;
  padding: 30rpx;
  color: #fff;
  font-size: 30rpx;
  margin-bottom: 30rpx;
}

.input-field::placeholder {
  color: #666;
}

.select-group {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
}

.select-btn {
  background: rgba(255, 255, 255, 0.08);
  border: 2rpx solid rgba(255, 255, 255, 0.1);
  border-radius: 30rpx;
  padding: 20rpx 40rpx;
  color: #fff;
  font-size: 28rpx;
  min-width: 150rpx;
  text-align: center;
}

.select-btn.active {
  background: linear-gradient(135deg, #ff6b9d 0%, #c44569 100%);
  border-color: transparent;
  box-shadow: 0 8rpx 24rpx rgba(255, 107, 157, 0.3);
}

.switch-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 30rpx 0;
  border-bottom: 1rpx solid rgba(255, 255, 255, 0.1);
}

.switch-label {
  font-size: 30rpx;
  color: #fff;
}

.tip {
  background: rgba(255, 107, 157, 0.1);
  border: 1rpx solid rgba(255, 107, 157, 0.3);
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 30rpx;
  font-size: 24rpx;
  color: #ff6b9d;
}

.empty-state {
  text-align: center;
  padding: 100rpx 50rpx;
}

.empty-icon {
  width: 200rpx;
  height: 200rpx;
  margin-bottom: 30rpx;
  opacity: 0.5;
}

.empty-text {
  font-size: 28rpx;
  color: #666;
}

.music-card {
  background: linear-gradient(135deg, #2a2a4a 0%, #1a1a2e 100%);
  border-radius: 20rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
  display: flex;
  align-items: center;
}

.music-cover {
  width: 100rpx;
  height: 100rpx;
  border-radius: 16rpx;
  background: linear-gradient(135deg, #ff6b9d 0%, #c44569 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 24rpx;
  font-size: 40rpx;
}

.music-info {
  flex: 1;
}

.music-title {
  font-size: 30rpx;
  color: #fff;
  margin-bottom: 8rpx;
}

.music-meta {
  font-size: 24rpx;
  color: #666;
}

.music-actions {
  display: flex;
  gap: 20rpx;
}

.action-btn {
  width: 60rpx;
  height: 60rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.1);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
}

.divider {
  height: 2rpx;
  background: rgba(255, 255, 255, 0.1);
  margin: 30rpx 0;
}

.progress-bar {
  width: 100%;
  height: 8rpx;
  background: rgba(255, 255, 255, 0.1);
  border-radius: 4rpx;
  overflow: hidden;
}

.progress-inner {
  height: 100%;
  background: linear-gradient(90deg, #ff6b9d 0%, #c44569 100%);
  border-radius: 4rpx;
  transition: width 0.3s ease;
}

.flex-row {
  display: flex;
  align-items: center;
}

.flex-between {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.flex-center {
  display: flex;
  justify-content: center;
  align-items: center;
}

.mt-20 {
  margin-top: 20rpx;
}

.mt-30 {
  margin-top: 30rpx;
}

.mb-20 {
  margin-bottom: 20rpx;
}

.mb-30 {
  margin-bottom: 30rpx;
}

.text-center {
  text-align: center;
}

.text-small {
  font-size: 24rpx;
}

.text-gray {
  color: #999;
}

.text-pink {
  color: #ff6b9d;
}

.tag {
  display: inline-block;
  padding: 6rpx 16rpx;
  background: rgba(255, 107, 157, 0.2);
  color: #ff6b9d;
  border-radius: 20rpx;
  font-size: 22rpx;
  margin-right: 10rpx;
}

.tag-blue {
  background: rgba(100, 149, 237, 0.2);
  color: #6495ed;
}

.tag-green {
  background: rgba(60, 179, 113, 0.2);
  color: #3cb371;
}

.tag-purple {
  background: rgba(147, 112, 219, 0.2);
  color: #9370db;
}

.modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.7);
  z-index: 1000;
  display: flex;
  align-items: center;
  justify-content: center;
}

.modal-content {
  background: #2a2a4a;
  border-radius: 24rpx;
  padding: 40rpx;
  width: 80%;
  max-width: 600rpx;
}

@keyframes spin {
  from { transform: rotate(0deg); }
  to { transform: rotate(360deg); }
}

@keyframes pulse {
  0%, 100% { opacity: 1; }
  50% { opacity: 0.5; }
}

@keyframes fadeIn {
  from { opacity: 0; transform: scale(0.95); }
  to { opacity: 1; transform: scale(1); }
}

.loading-spin {
  animation: spin 1s linear infinite;
}

.loading-pulse {
  animation: pulse 1.5s ease-in-out infinite;
}

.fade-in {
  animation: fadeIn 0.3s ease-out;
}
