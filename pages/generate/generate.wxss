/* ========== 独家壁垒：处理流水线状态 ========== */
.pipeline-status {
  background: linear-gradient(135deg, #2a2a4a 0%, #1a1a2e 100%);
  border-radius: 16rpx;
  padding: 30rpx;
  margin: 30rpx 40rpx;
}

.pipeline-title {
  font-size: 28rpx;
  color: #ff6b9d;
  margin-bottom: 20rpx;
  text-align: center;
}

.pipeline-item {
  display: flex;
  align-items: center;
  padding: 16rpx 20rpx;
  background: rgba(255, 255, 255, 0.05);
  border-radius: 10rpx;
  margin-bottom: 12rpx;
}

.pipeline-item:last-child {
  margin-bottom: 0;
}

.pipeline-item.passed {
  background: rgba(76, 175, 80, 0.15);
  border-left: 4rpx solid #4CAF50;
}

.pipeline-item.checking {
  background: rgba(255, 152, 0, 0.15);
  border-left: 4rpx solid #FF9800;
}

.pipeline-item.failed {
  background: rgba(244, 67, 54, 0.15);
  border-left: 4rpx solid #F44336;
}

.pipeline-icon {
  font-size: 32rpx;
  margin-right: 16rpx;
}

.pipeline-text {
  flex: 1;
  font-size: 26rpx;
  color: #fff;
}

.pipeline-score {
  font-size: 24rpx;
  color: #4CAF50;
  font-weight: bold;
}

.pipeline-badge {
  font-size: 22rpx;
  background: #4CAF50;
  color: #fff;
  padding: 4rpx 12rpx;
  border-radius: 20rpx;
}

/* ========== 独家壁垒：质量标识条 ========== */
.quality-badge-bar {
  display: flex;
  justify-content: center;
  gap: 20rpx;
  padding: 20rpx 40rpx;
  background: #1a1a2e;
}

.quality-badge {
  display: flex;
  align-items: center;
  padding: 10rpx 20rpx;
  background: rgba(255, 255, 255, 0.1);
  border-radius: 30rpx;
  font-size: 24rpx;
  color: #999;
}

.quality-badge.badge-pass {
  background: rgba(76, 175, 80, 0.2);
  color: #4CAF50;
}

.quality-badge.badge-warn {
  background: rgba(255, 152, 0, 0.2);
  color: #FF9800;
}

.badge-icon {
  margin-right: 8rpx;
  font-size: 28rpx;
}

.badge-score {
  margin-left: 10rpx;
  font-weight: bold;
}

/* ========== 独家壁垒：高潮片段卡片 ========== */
.hook-card {
  margin: 20rpx 40rpx;
  background: linear-gradient(135deg, #1a3a2a 0%, #0a1a10 100%);
  border: 2rpx solid #4CAF50;
}

.hook-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.hook-title {
  font-size: 32rpx;
  color: #4CAF50;
  font-weight: bold;
}

.hook-duration {
  font-size: 24rpx;
  color: #4CAF50;
  background: rgba(76, 175, 80, 0.2);
  padding: 6rpx 16rpx;
  border-radius: 20rpx;
}

.hook-info {
  margin-bottom: 20rpx;
}

.hook-desc {
  font-size: 26rpx;
  color: #999;
}

.hook-actions {
  display: flex;
  gap: 20rpx;
}

/* ========== 独家壁垒：分发卡片 ========== */
.distribute-card {
  margin: 20rpx 40rpx;
  background: linear-gradient(135deg, #2a2a5a 0%, #1a1a3e 100%);
  border: 2rpx solid #ff6b9d;
}

.distribute-header {
  margin-bottom: 20rpx;
}

.distribute-title {
  font-size: 32rpx;
  color: #ff6b9d;
  font-weight: bold;
}

.platform-list {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  margin-bottom: 20rpx;
}

.platform-item {
  display: flex;
  align-items: center;
  padding: 10rpx 16rpx;
  background: rgba(255, 255, 255, 0.1);
  border-radius: 30rpx;
  font-size: 24rpx;
}

.platform-item text:first-child {
  margin-right: 8rpx;
  font-size: 28rpx;
}

.platform-name {
  color: #fff;
}

.btn-distribute {
  background: linear-gradient(135deg, #ff6b9d 0%, #c44569 100%);
  color: #fff;
  border: none;
  border-radius: 40rpx;
  padding: 20rpx;
  font-size: 30rpx;
  font-weight: bold;
}

/* ========== 通用样式 ========== */
.generating-area {
  text-align: center;
  padding: 60rpx 0;
}

.loading-icon {
  font-size: 120rpx;
  margin-bottom: 40rpx;
}

.loading-spin {
  font-size: 120rpx;
  display: inline-block;
  animation: spin 2s linear infinite;
}

.loading-title {
  font-size: 40rpx;
  font-weight: bold;
  color: #fff;
  margin-bottom: 16rpx;
}

.loading-subtitle {
  font-size: 26rpx;
  color: #999;
  margin-bottom: 60rpx;
}

.progress-container {
  padding: 0 40rpx;
  margin-bottom: 40rpx;
}

.progress-bar {
  height: 8rpx;
  background: rgba(255, 255, 255, 0.1);
  border-radius: 4rpx;
  overflow: visible;
  position: relative;
}

.progress-inner {
  height: 100%;
  background: linear-gradient(90deg, #ff6b9d, #c44569);
  border-radius: 4rpx;
  transition: width 0.3s ease;
}

.progress-text {
  font-size: 24rpx;
  color: #ff6b9d;
  margin-top: 16rpx;
  display: block;
}

.generating-steps {
  display: flex;
  justify-content: center;
  align-items: center;
  padding: 0 20rpx;
  flex-wrap: wrap;
}

.step {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.step-icon {
  width: 50rpx;
  height: 50rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.1);
  color: #666;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  margin-bottom: 10rpx;
  transition: all 0.3s;
}

.step.active .step-icon {
  background: linear-gradient(135deg, #ff6b9d 0%, #c44569 100%);
  color: #fff;
}

.step-text {
  font-size: 22rpx;
  color: #666;
}

.step.active .step-text {
  color: #ff6b9d;
}

.step-line {
  width: 40rpx;
  height: 2rpx;
  background: rgba(255, 255, 255, 0.1);
  margin: 0 10rpx;
  margin-bottom: 30rpx;
  transition: background 0.3s;
}

.step-line.active {
  background: #ff6b9d;
}

/* 结果页面样式 */
.card {
  background: linear-gradient(135deg, #2a2a4a 0%, #1a1a2e 100%);
  border-radius: 20rpx;
  padding: 40rpx;
  margin: 20rpx 40rpx;
}

.result-card {
  text-align: center;
}

.music-visual {
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 40rpx;
}

.music-disc {
  width: 180rpx;
  height: 180rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #2a2a4a 0%, #1a1a2e 100%);
  border: 8rpx solid #3a3a5a;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 30rpx;
}

.disc-icon {
  font-size: 60rpx;
}

.music-disc.spinning {
  animation: spin 8s linear infinite;
}

.music-waves {
  display: flex;
  align-items: flex-end;
  height: 60rpx;
  gap: 6rpx;
}

.wave {
  width: 8rpx;
  height: 20rpx;
  background: #ff6b9d;
  border-radius: 4rpx;
  animation: wave 0.8s ease-in-out infinite;
}

.wave-2 {
  animation-delay: 0.2s;
  height: 35rpx;
}

.wave-3 {
  animation-delay: 0.4s;
  height: 45rpx;
}

.wave.active {
  animation-play-state: running;
}

.music-waves:not(.active) .wave {
  animation: none;
  height: 15rpx;
}

@keyframes wave {
  0%, 100% { transform: scaleY(0.5); }
  50% { transform: scaleY(1); }
}

.music-title-large {
  font-size: 40rpx;
  color: #fff;
  font-weight: bold;
  margin-bottom: 16rpx;
}

.music-tags {
  display: flex;
  justify-content: center;
  gap: 16rpx;
  margin-bottom: 30rpx;
  flex-wrap: wrap;
}

.tag {
  font-size: 24rpx;
  padding: 8rpx 16rpx;
  background: rgba(255, 255, 255, 0.1);
  border-radius: 20rpx;
  color: #999;
}

.tag-blue {
  background: rgba(33, 150, 243, 0.2);
  color: #2196F3;
}

.tag-green {
  background: rgba(76, 175, 80, 0.2);
  color: #4CAF50;
}

.play-control {
  margin-top: 20rpx;
}

.progress-section {
  display: flex;
  align-items: center;
  margin-bottom: 20rpx;
}

.time-text {
  font-size: 22rpx;
  color: #999;
  width: 80rpx;
  text-align: center;
}

.progress-bar {
  flex: 1;
  height: 6rpx;
  background: rgba(255, 255, 255, 0.1);
  border-radius: 3rpx;
  margin: 0 16rpx;
  position: relative;
}

.progress-dot {
  width: 16rpx;
  height: 16rpx;
  background: #ff6b9d;
  border-radius: 50%;
  position: absolute;
  top: 50%;
  transform: translate(-50%, -50%);
  box-shadow: 0 0 10rpx rgba(255, 107, 157, 0.5);
}

.play-buttons {
  display: flex;
  justify-content: center;
  align-items: center;
  gap: 40rpx;
}

.play-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
}

.main-btn {
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #ff6b9d 0%, #c44569 100%);
  font-size: 48rpx;
}

.prev-btn, .next-btn {
  width: 60rpx;
  height: 60rpx;
  font-size: 32rpx;
}

/* 操作按钮 */
.action-card {
  margin-top: 20rpx;
}

.action-title {
  font-size: 30rpx;
  color: #fff;
  margin-bottom: 24rpx;
  text-align: center;
}

.action-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 20rpx;
}

.action-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 20rpx 10rpx;
  background: rgba(255, 255, 255, 0.05);
  border-radius: 16rpx;
}

.action-icon {
  font-size: 40rpx;
  margin-bottom: 10rpx;
}

.action-text {
  font-size: 24rpx;
  color: #fff;
}

.action-sub {
  font-size: 20rpx;
  color: #666;
  margin-top: 4rpx;
}

/* 按钮样式 */
.btn-primary {
  background: linear-gradient(135deg, #ff6b9d 0%, #c44569 100%);
  color: #fff;
  border: none;
  border-radius: 40rpx;
}

.btn-secondary {
  background: rgba(255, 255, 255, 0.1);
  color: #fff;
  border: 2rpx solid rgba(255, 255, 255, 0.2);
  border-radius: 40rpx;
}

.btn-small {
  padding: 12rpx 30rpx;
  font-size: 26rpx;
}

.back-home {
  text-align: center;
  padding: 40rpx;
  color: #999;
  font-size: 26rpx;
}

/* 错误页面 */
.error-area {
  text-align: center;
  padding: 200rpx 40rpx;
}

.error-icon {
  font-size: 150rpx;
  display: block;
  margin-bottom: 30rpx;
}

.error-text {
  font-size: 30rpx;
  color: #999;
  margin-bottom: 40rpx;
}

/* 动画 */
@keyframes spin {
  from { transform: rotate(0deg); }
  to { transform: rotate(360deg); }
}

.fade-in {
  animation: fadeIn 0.5s ease-out;
}

@keyframes fadeIn {
  from { opacity: 0; transform: translateY(20rpx); }
  to { opacity: 1; transform: translateY(0); }
}

/* 通用样式 */
.container {
  min-height: 100vh;
  background: #1a1a2e;
  padding-bottom: 40rpx;
}
