.header {
  padding: 30rpx 0;
}

.title {
  font-size: 40rpx;
  font-weight: bold;
  display: block;
  margin-bottom: 10rpx;
}

.subtitle {
  font-size: 26rpx;
  color: #999;
}

.empty-state {
  padding-top: 150rpx;
}

.empty-icon {
  font-size: 150rpx;
  display: block;
  text-align: center;
  margin-bottom: 30rpx;
  opacity: 0.5;
}

.empty-text {
  font-size: 32rpx;
  color: #fff;
  text-align: center;
  margin-bottom: 16rpx;
}

.empty-sub {
  font-size: 26rpx;
  color: #666;
  text-align: center;
}

.music-list {
  padding-top: 10rpx;
}

.music-card {
  display: flex;
  align-items: center;
  padding: 24rpx;
  background: linear-gradient(135deg, #2a2a4a 0%, #1a1a2e 100%);
  border-radius: 16rpx;
  margin-bottom: 20rpx;
}

.music-cover {
  width: 90rpx;
  height: 90rpx;
  border-radius: 12rpx;
  background: linear-gradient(135deg, #ff6b9d 0%, #c44569 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 20rpx;
  font-size: 36rpx;
  flex-shrink: 0;
}

.music-info {
  flex: 1;
  min-width: 0;
}

.music-title {
  font-size: 30rpx;
  color: #fff;
  margin-bottom: 8rpx;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.music-meta {
  font-size: 24rpx;
  color: #666;
}

.ml-20 {
  margin-left: 20rpx;
}

.music-actions {
  display: flex;
  gap: 16rpx;
  margin-left: 20rpx;
}

.action-btn {
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.1);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 26rpx;
  transition: all 0.2s;
}

.action-btn:active {
  background: rgba(255, 107, 157, 0.3);
}

.action-btn.playing {
  background: linear-gradient(135deg, #ff6b9d 0%, #c44569 100%);
  animation: pulse 1.5s ease-in-out infinite;
}

/* 操作菜单 */
.action-sheet {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.6);
  z-index: 1000;
  display: flex;
  align-items: flex-end;
  justify-content: center;
}

.action-sheet-content {
  background: #2a2a4a;
  border-radius: 24rpx 24rpx 0 0;
  width: 100%;
  padding: 30rpx 0;
  padding-bottom: calc(30rpx + env(safe-area-inset-bottom));
  animation: slideUp 0.3s ease-out;
}

@keyframes slideUp {
  from {
    transform: translateY(100%);
  }
  to {
    transform: translateY(0);
  }
}

.action-sheet-title {
  text-align: center;
  font-size: 28rpx;
  color: #999;
  padding-bottom: 30rpx;
  border-bottom: 1rpx solid rgba(255, 255, 255, 0.1);
  margin-bottom: 10rpx;
}

.action-sheet-item {
  display: flex;
  align-items: center;
  padding: 30rpx 40rpx;
  font-size: 30rpx;
  color: #fff;
  transition: background 0.2s;
}

.action-sheet-item:active {
  background: rgba(255, 255, 255, 0.05);
}

.action-sheet-item.danger {
  color: #ff6b6d;
}

.action-icon {
  font-size: 36rpx;
  margin-right: 20rpx;
}

.action-sheet-cancel {
  text-align: center;
  font-size: 30rpx;
  color: #999;
  padding: 30rpx;
  margin-top: 20rpx;
  border-top: 1rpx solid rgba(255, 255, 255, 0.1);
}

/* 重命名弹窗 */
.modal-title {
  font-size: 32rpx;
  font-weight: bold;
  margin-bottom: 30rpx;
  text-align: center;
}

.modal-actions {
  display: flex;
  gap: 20rpx;
  margin-top: 30rpx;
}

.modal-actions button {
  flex: 1;
}

/* 播放提示 */
.playing-tip {
  position: fixed;
  top: 100rpx;
  left: 50%;
  transform: translateX(-50%);
  background: linear-gradient(135deg, #ff6b9d 0%, #c44569 100%);
  padding: 16rpx 30rpx;
  border-radius: 50rpx;
  font-size: 24rpx;
  color: #fff;
  z-index: 999;
  box-shadow: 0 8rpx 24rpx rgba(255, 107, 157, 0.4);
  white-space: nowrap;
}
